generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id // Clerk user ID
  email     String   @unique
  createdAt DateTime @default(now())

  sessions      PracticeSession[]
  flScores      FullLengthScore[]
  notes         UserNote[]
  studyTasks    StudyTask[]
}

model Question {
  id              String   @id @default(cuid())
  section         String   // "Chem/Phys" | "CARS" | "Bio/Biochem" | "Psych/Soc"
  topic           String
  passage         String?
  stem            String
  optionA         String
  optionB         String
  optionC         String
  optionD         String
  correctAnswer   String   // "A" | "B" | "C" | "D"
  explanation     String
  difficulty      String   @default("medium") // "easy" | "medium" | "hard"
  aiGenerated     Boolean  @default(true)
  createdAt       DateTime @default(now())

  sessionQuestions SessionQuestion[]
}

model PracticeSession {
  id        String   @id @default(cuid())
  userId    String
  section   String
  startedAt DateTime @default(now())
  endedAt   DateTime?
  timeLimitSeconds Int?

  user      User               @relation(fields: [userId], references: [id])
  questions SessionQuestion[]
}

model SessionQuestion {
  id          String   @id @default(cuid())
  sessionId   String
  questionId  String
  userAnswer  String?  // "A" | "B" | "C" | "D"
  isCorrect   Boolean?
  errorType   String?  // "Content Gap" | "Logic Error" | "Misread Question" | "Timing"
  flagged     Boolean  @default(false)
  confidence  String?  // "low" | "medium" | "high"
  reviewStatus String  @default("pending") // "pending" | "reviewed"
  answeredAt  DateTime?

  session     PracticeSession @relation(fields: [sessionId], references: [id])
  question    Question        @relation(fields: [questionId], references: [id])
}

model FullLengthScore {
  id        String   @id @default(cuid())
  userId    String
  testName  String
  chemPhys  Int
  cars      Int
  bioBiochem Int
  psychSoc  Int
  total     Int
  takenAt   DateTime @default(now())

  user      User @relation(fields: [userId], references: [id])
}

model UserNote {
  id         String   @id @default(cuid())
  userId     String
  questionId String?
  topic      String?
  content    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User @relation(fields: [userId], references: [id])
}

model StudyTask {
  id          String   @id @default(cuid())
  userId      String
  title       String
  section     String?
  dueDate     DateTime?
  completed   Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User @relation(fields: [userId], references: [id])
}
